# URL do backend Python (Vercel Serverless)
# Em desenvolvimento local tradicional: http://localhost:8000
# Usando Vercel CLI (npx vercel dev): pode ser deixado em branco, pois roda no mesmo domínio (ex: http://localhost:3000)
# Em produção na Vercel: DEIXAR EM BRANCO ou não configurar (roda 100% no mesmo domínio)
NEXT_PUBLIC_API_URL=

# Credenciais compartilhadas pelo Next.js e pelo Backend Python
GOOGLE_API_KEY=
SPREADSHEET_ID=
GEMINI_API_KEY=

# ── Agente IA — providers opcionais (cascade automático) ──
# O agente usa o melhor modelo disponível e cai para os mais fracos se o limite acabar.
# Basta configurar as keys dos providers que quiser usar.
# Ordem: Gemini Pro → GPT-4o → Gemini Flash → DeepSeek → Groq → Gemini 2.0 Flash → GPT-4o Mini
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# ── Reddit (opcional, mas recomendado) ──
# O Reddit bloqueia IPs de datacenter (Vercel) em todos os endpoints públicos.
# A página de Notícias tem fallback que busca direto do navegador do usuário,
# mas o acesso 100% confiável é via API oficial OAuth.
# Como obter (grátis): https://www.reddit.com/prefs/apps → "create app" →
#   tipo "script" → copie o client id (abaixo do nome) e o secret.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
