# Google Sheets API Key (obtenha em console.cloud.google.com > APIs & Services > Credentials)
GOOGLE_API_KEY=sua_api_key_aqui

# ID da planilha (extraído da URL do Google Sheets)
SPREADSHEET_ID=seu_spreadsheet_id_aqui

# Gemini API Key (agente IA — aistudio.google.com/apikey)
GEMINI_API_KEY=sua_gemini_key_aqui
