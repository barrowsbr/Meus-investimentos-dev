# Google Sheets API Key (obtenha em console.cloud.google.com > APIs & Services > Credentials)
GOOGLE_API_KEY=sua_api_key_aqui

# ID da planilha (extraído da URL do Google Sheets)
SPREADSHEET_ID=seu_spreadsheet_id_aqui

# Gemini API Key (agente IA — aistudio.google.com/apikey)
GEMINI_API_KEY=sua_gemini_key_aqui

# Alpha Vantage (holdings completos de ETFs US — alphavantage.co/support/#api-key, free 25 req/dia)
ALPHAVANTAGE_API_KEY=sua_alphavantage_key_aqui

# Groq (fallback gratuito da cascata de IA — console.groq.com)
GROQ_API_KEY=sua_groq_key_aqui

# Grok / xAI (comentário do dia na página "Hoje" — console.x.ai).
# Opcional: se ausente, o comentário cai na cascata de IA acima (Gemini/OpenAI/Groq).
XAI_API_KEY=sua_xai_key_aqui

# IBKR Flex Web Service (sync automático de trades/proventos sem gateway).
# Client Portal → Performance & Reports → Flex Queries (Activity, formato XML) = Query ID.
# Performance & Reports → Settings → Flex Web Service = Token (validade ~1 ano).
IBKR_FLEX_TOKEN=seu_flex_token_aqui
IBKR_FLEX_QUERY_ID=seu_query_id_aqui
