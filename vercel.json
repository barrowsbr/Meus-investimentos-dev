{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/cotacoes",
      "schedule": "0 23 * * 1-5"
    },
    {
      "path": "/api/cron/ibkr",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/alertas",
      "schedule": "30 9 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 21 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/fluxos",
      "destination": "/api/index"
    },
    {
      "source": "/api/historico/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/api/agent/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/api/preditivo/:path*",
      "destination": "/api/index"
    }
  ]
}
